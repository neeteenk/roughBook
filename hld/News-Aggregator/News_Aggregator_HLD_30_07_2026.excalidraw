      "isDeleted": false,
      "boundElements": [],
      "updated": 1782788277952,
      "link": null,
      "locked": false,
      "text": "FRs\n\n- Users should be able to view an aggregated feed of news\n articles from thousands of source publishers all over the \n world.\n- User should be able to scroll the feed indefinitely\n- User should be able to click on articles and redirect to\n  publishers website to read the full article.\n\nOut of Scope:\n- User to customize feed based on interest\n- User should be able to read article for reading later",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FRs\n\n- Users should be able to view an aggregated feed of news\n articles from thousands of source publishers all over the \n world.\n- User should be able to scroll the feed indefinitely\n- User should be able to click on articles and redirect to\n  publishers website to read the full article.\n\nOut of Scope:\n- User to customize feed based on interest\n- User should be able to read article for reading later",
      "autoResize": true,
      "lineHeight": 1.25
    },
