      "isDeleted": false,
      "boundElements": null,
      "updated": 1782803995053,
      "link": null,
      "locked": false,
      "text": "1) How can we improve pagination consistency and efficiency?",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1) How can we improve pagination consistency and efficiency?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "FyfmsV2BKpZQtZ9cZXyAH",
      "type": "text",
      "x": -1615.1595266238155,
      "y": 6360.71549551968,
      "width": 1094.1556396484375,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b39",
      "roundness": null,
      "seed": 1317946564,
      "version": 105,
      "versionNonce": 1342614980,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782804238036,
      "link": null,
      "locked": false,
      "text": "LIMIT OFFSET        \nDuplicates or missing articles when new rows are inserted\n\nTimestamp cursor\nPrevents pagination drift but fails if multiple articles share the same timestamp\n\n(timestamp, id) cursor\nPrevents both drift and timestamp collisions\n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "LIMIT OFFSET        \nDuplicates or missing articles when new rows are inserted\n\nTimestamp cursor\nPrevents pagination drift but fails if multiple articles share the same timestamp\n\n(timestamp, id) cursor\nPrevents both drift and timestamp collisions\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "PKb7iz2zmGAz26-v_Q1pi",
      "type": "text",
      "x": -364.21098765537283,
      "y": 6245.966735432255,
      "width": 206.5609442850044,
      "height": 594.4979987668047,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3A",
      "roundness": null,
      "seed": 1805970428,
      "version": 256,
      "versionNonce": 32893948,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782804233169,
      "link": null,
      "locked": false,
      "text": "SELECT *\nFROM articles\nWHERE\n(\n    published_at,\n    article_id\n)\n<\n(\n    '10:08',\n    8\n)\nORDER BY\npublished_at DESC,\narticle_id DESC\nLIMIT 3;\n\n\nRows\n10:08 id=7\n10:08 id=6\n10:07 id=5",
      "fontSize": 21.618109046065626,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SELECT *\nFROM articles\nWHERE\n(\n    published_at,\n    article_id\n)\n<\n(\n    '10:08',\n    8\n)\nORDER BY\npublished_at DESC,\narticle_id DESC\nLIMIT 3;\n\n\nRows\n10:08 id=7\n10:08 id=6\n10:07 id=5",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mbsUhbCw0BI2-EYt7wgon",
      "type": "rectangle",
      "x": -397.4003533713893,
      "y": 6230.872801029183,
      "width": 319.8420821460683,
      "height": 615.4514480939442,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
