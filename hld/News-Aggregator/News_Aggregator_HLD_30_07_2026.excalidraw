    {
      "id": "3GSgUZxbz_Zmw3xu5gyE3",
      "type": "text",
      "x": -1642.0057426707533,
      "y": 6289.8002965711785,
      "width": 825.9436645507812,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
