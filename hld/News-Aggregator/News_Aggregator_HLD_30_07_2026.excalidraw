      "updated": 1782788379491,
      "link": null,
      "locked": false,
      "text": "NFRs\n- Avalability >> Consistency\n- The system should be scalable to handle 100 million daily \n active users with spikes up to 500 million\n- System should have low latency feed times (< 200 ms)",
      "fontSize": 28.685896270996928,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NFRs\n- Avalability >> Consistency\n- The system should be scalable to handle 100 million daily \n active users with spikes up to 500 million\n- System should have low latency feed times (< 200 ms)",
      "autoResize": true,
      "lineHeight": 1.25
    },
