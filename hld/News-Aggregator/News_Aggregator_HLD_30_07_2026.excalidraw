    },
    {
      "id": "WMeqUfoCe4j4wbRACUPbg",
      "type": "text",
      "x": -3759.4147945755726,
      "y": 6284.664376291259,
      "width": 1830.4986572265625,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
