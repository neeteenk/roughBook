      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Article\n\nPublisher (Represents a news source with attributes like id, name, \nURL, feed URL, and region. Publishers are the origin of our content)\n\nUser",
      "autoResize": true,
      "lineHeight": 1.25
    },
