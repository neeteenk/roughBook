    },
    {
      "id": "sNgwOOuMxXCLh9fdK17wI",
      "type": "text",
      "x": -1635.1435688032238,
      "y": 6908.490922042733,
      "width": 821.043701171875,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3C",
