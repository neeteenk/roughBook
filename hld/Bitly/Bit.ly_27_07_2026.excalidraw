,"id":"NuE7V13ZJ37DtGdi4ubdT","strokeWidth":1,"roughness":1,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1774336402685,"locked":false,"text":"Cache\n(Redis)","version":33,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2w","roundness":null,"containerId":null,"originalText":"Cache\n(Redis)","height":70,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":472306532,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"VZpmme2OCV0jKUfP9wd4Z","type":"arrow"}],"x":-4765.2469165906941,"angle":0,"y":6801.8545444573729,"width":98.22393798828125},{"seed":361318108,"strokeStyle":"solid","id":"oEYaarkiQ2dTPLg1cr2kz","strokeWidth":1,"roughness":1,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1774335605979,"locked":false,"text":"k(shorturl): v(longUrl)","version":52,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2x","roundness":null,"containerId":null,"originalText":"k(shorturl): v(longUrl)","height":35,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":912840028,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-4631.9697853739699,"angle":0,"y":6849.9335856765092,"width":295.98785400390625},{"seed":305662180,"strokeStyle":"solid","id":"BieeVTly-IcxCOX4BFUJu","strokeWidth":1,"roughness":1,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1782548144849,"locked":false,"text":"Redis is particularly well-suited for managing this counter because it's single-threaded and supports atomic operations\nBest Approach: Redix INCR command generates atomically unique counter \nwhich we can then have BASE62((a-z, A-Z, 0-9)(It's a compact representation of numbers that \nuses 62 characters) encoded to get unique shortCode\nDownside: Is user can predict the generation of shortCode which is fine since shortUrls are \nanyway public.\nBASE62 -> we take 6 characters -> 62^6 = ~56.8B URLs which satisifes able to support 1B urls\nEach Write Service instance requests a batch of counter values from the Redis instance so would n't\nhabe to request Redis Counter for each new Url creation\n\nApproach 2 -> SHA256 would give fixed hash code but if we take first 8\/7 characters we \nwill get collision with scale.","version":745,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2z","roundness":null,"containerId":null,"originalText":"Redis is particularly well-suited for managing this counter because it's single-threaded and supports atomic operations\nBest Approach: Redix INCR command generates atomically unique counter \nwhich we can then have BASE62((a-z, A-Z, 0-9)(It's a compact representation of numbers that \nuses 62 characters) encoded to get unique shortCode\nDownside: Is user can predict the generation of shortCode which is fine since shortUrls are \nanyway public.\nBASE62 -> we take 6 characters -> 62^6 = ~56.8B URLs which satisifes able to support 1B urls\nEach Write Service instance requests a batch of counter values from the Redis instance so would n't\nhabe to request Redis Counter for each new Url creation\n\nApproach 2 -> SHA256 would give fixed hash code but if we take first 8\/7 characters we \nwill get collision with scale.","height":420,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":457380054,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"sNU3cfuDHIWuEjrTWBtwH","type":"arrow"}],"x":-4721.825519803735,"angle":0,"y":5996.1434198480447,"width":1619.548095703125},{"seed":868232796,"strokeStyle":"solid","id":"sNU3cfuDHIWuEjrTWBtwH","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"RaVE518yXUkuc31JiJnsz","fixedPoint":[0.50009999999999999,0]},"endArrowhead":"arrow","opacity":100,"updated":1782548144849,"locked":false,"points":[[0,